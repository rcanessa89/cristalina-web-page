---
import Layout from '../../layouts/Layout.astro';
import { getPageContent } from '../../lib/contentful';
import { mapPage } from '../../lib/mapContent';
import ComponentResolver from '../../components/ComponentResolver.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'home' } },
    { params: { slug: 'water-tec-premium' } },
    { params: { slug: 'water-tec-pro' } },
    { params: { slug: 'how-it-works' } },
    { params: { slug: 'maintenance' } },
    { params: { slug: 'about-us' } },
    { params: { slug: 'contact' } }
  ];
}

const { slug } = Astro.params;
const data = await getPageContent(slug, 'en');
const page = data ? mapPage(data) : null;
---

<Layout
  title={page?.title}
  description={page?.metaDescription}
  ogImage={page?.ogImage?.url}
  slug={slug}
>
  {page && <ComponentResolver components={page.components} locale="en" />}
</Layout>
