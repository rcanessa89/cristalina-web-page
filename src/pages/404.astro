---
import '../styles/global.css';
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preload" href="/fonts/plus-jakarta-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/outfit-latin.woff2" as="font" type="font/woff2" crossorigin />
		<title>404 - Pagina no encontrada | Cristalina</title>
		<meta name="robots" content="noindex, nofollow" />
	</head>
	<body class="font-jakarta bg-base-100 min-h-screen flex items-center justify-center">
		<div class="text-center px-6 max-w-lg">
			<p class="text-8xl font-outfit font-black text-primary mb-4">404</p>
			<h1 class="text-2xl md:text-3xl font-outfit font-bold text-neutral mb-4">Pagina no encontrada</h1>
			<p class="text-base-content/70 mb-8">La pagina que buscas no existe o fue movida.</p>
			<div class="flex flex-col sm:flex-row gap-3 justify-center">
				<a href="/es/inicio" class="btn btn-primary btn-lg text-white">Ir al inicio</a>
				<a href="/en/home" class="btn btn-outline btn-lg">Go to Home</a>
			</div>
		</div>
	</body>
</html>
