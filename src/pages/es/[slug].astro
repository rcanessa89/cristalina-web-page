---
import Layout from '../../layouts/Layout.astro';
import { getPageContent } from '../../lib/contentful';
import { mapPage } from '../../lib/mapContent';
import ComponentResolver from '../../components/ComponentResolver.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'inicio' } },
    { params: { slug: 'water-tec-premium' } },
    { params: { slug: 'water-tec-pro' } },
    { params: { slug: 'como-funciona' } },
    { params: { slug: 'mantenimiento' } },
    { params: { slug: 'nosotros' } },
    { params: { slug: 'contacto' } }
  ];
}

const { slug } = Astro.params;
const data = await getPageContent(slug, 'es');
const page = data ? mapPage(data) : null;

if (!page) {
  return Astro.redirect('/404');
}
---

<Layout
  title={page.title}
  description={page.metaDescription}
  ogImage={page.ogImage?.url}
  slug={slug}
>
  <ComponentResolver components={page.components} locale="es" />
</Layout>
