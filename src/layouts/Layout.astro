---
import '../styles/global.css';
import Navigation from '../components/Navigation';
import Footer from '../components/Footer';
import { getNavigation, getFooter } from '../lib/contentful';
import { mapNavigation, mapFooter } from '../lib/mapContent';

interface Props {
	title?: string;
}

const { title = 'Cristalina' } = Astro.props;
const locale = (Astro.currentLocale as 'es' | 'en') ?? 'es';
const navData = await getNavigation(locale);
const footerData = await getFooter(locale);
const navigation = navData ? mapNavigation(navData) : { links: [] };
const footer = footerData ? mapFooter(footerData) : null;
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<Navigation links={navigation.links} />
		<main>
			<slot />
		</main>
		{footer && <Footer {...footer} />}
	</body>
</html>
