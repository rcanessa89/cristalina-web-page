---
import '../styles/global.css';
import Navigation from '../components/Navigation';
import { getNavigation } from '../lib/contentful';
import { mapNavigation } from '../lib/mapContent';

interface Props {
	title?: string;
}

const { title = 'Cristalina' } = Astro.props;
const locale = (Astro.currentLocale as 'es' | 'en') ?? 'es';
const navData = await getNavigation(locale);
const navigation = navData ? mapNavigation(navData) : { links: [] };
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<Navigation links={navigation.links} />
		<slot />
	</body>
</html>
