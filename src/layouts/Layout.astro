---
import '../styles/global.css';
import { SEO } from 'astro-seo';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { getNavigation, getFooter } from '../lib/contentful';
import { mapNavigation, mapFooter } from '../lib/mapContent';
import { getAlternateSlug, getDefaultDescription } from '../lib/seo';

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	slug?: string;
}

const { title = 'Cristalina', description, ogImage, slug = '' } = Astro.props;
const locale = (Astro.currentLocale as 'es' | 'en') ?? 'es';
const navData = await getNavigation(locale);
const footerData = await getFooter(locale);
const navigation = navData ? mapNavigation(navData) : { links: [] };
const footer = footerData ? mapFooter(footerData) : null;

// SEO
const siteUrl = 'https://www.cristalinacr.com';
const canonicalURL = new URL(Astro.url.pathname, siteUrl).toString();
const metaDescription = description || getDefaultDescription(slug, locale);
const isHome = slug === 'inicio' || slug === 'home';
const fullTitle = isHome
	? 'Cristalina | ' + (locale === 'es' ? 'Tratamiento de Agua en Costa Rica' : 'Water Treatment in Costa Rica')
	: title && title !== 'Cristalina' ? title : slug.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
const defaultOgImage = `${siteUrl}/og-default.png`;
const ogImageUrl = ogImage || defaultOgImage;

// Hreflang alternates
const altSlug = getAlternateSlug(slug, locale);
const esUrl = `${siteUrl}/es/${locale === 'es' ? slug : altSlug}`;
const enUrl = `${siteUrl}/en/${locale === 'en' ? slug : altSlug}`;

// Structured Data - Organization
const organizationSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "Organization",
	"name": "Cristalina",
	"url": siteUrl,
	"logo": `${siteUrl}/favicon.svg`,
	"contactPoint": {
		"@type": "ContactPoint",
		"telephone": "+(506) 8849-5919",
		"contactType": "sales",
		"areaServed": "CR",
		"availableLanguage": ["Spanish", "English"]
	},
	"sameAs": ["https://www.facebook.com/Cristalina.Agua.Pura"]
});

// Structured Data - LocalBusiness (only on home)
const localBusinessSchema = isHome ? JSON.stringify({
	"@context": "https://schema.org",
	"@type": "LocalBusiness",
	"name": "Cristalina",
	"description": locale === 'es'
		? "Soluciones de tratamiento y purificacion de agua en Costa Rica"
		: "Water treatment and purification solutions in Costa Rica",
	"url": siteUrl,
	"telephone": "+(506) 8849-5919",
	"address": {
		"@type": "PostalAddress",
		"streetAddress": "50 E. del B.C.R. - Urb. Vizcaya No.87",
		"addressLocality": "San Rafael Abajo de Desamparados",
		"addressRegion": "San Jose",
		"addressCountry": "CR"
	},
	"geo": {
		"@type": "GeoCoordinates",
		"latitude": 9.9,
		"longitude": -84.05
	},
	"sameAs": ["https://www.facebook.com/Cristalina.Agua.Pura"],
	"priceRange": "$$"
}) : null;

// Structured Data - BreadcrumbList
const breadcrumbSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": locale === 'es' ? 'Inicio' : 'Home',
			"item": `${siteUrl}/${locale}/${locale === 'es' ? 'inicio' : 'home'}`
		},
		...(isHome ? [] : [{
			"@type": "ListItem",
			"position": 2,
			"name": title,
			"item": canonicalURL
		}])
	]
});

// Structured Data - Product (product pages)
const isProduct = slug === 'water-tec-premium' || slug === 'water-tec-pro';
const productSchema = isProduct ? JSON.stringify({
	"@context": "https://schema.org",
	"@type": "Product",
	"name": title,
	"description": metaDescription,
	"brand": {
		"@type": "Brand",
		"name": "Cristalina"
	},
	"category": locale === 'es' ? "Purificadores de Agua" : "Water Purifiers",
	"manufacturer": {
		"@type": "Organization",
		"name": "Cristalina"
	}
}) : null;

// Structured Data - WebSite (home only — enables sitelinks searchbox)
const webSiteSchema = isHome ? JSON.stringify({
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "Cristalina",
	"url": siteUrl,
	"inLanguage": ["es", "en"],
	"description": locale === 'es'
		? "Soluciones de tratamiento y purificación de agua en Costa Rica"
		: "Water treatment and purification solutions in Costa Rica"
}) : null;

// Structured Data - AboutPage
const isAbout = slug === 'nosotros' || slug === 'about-us';
const aboutPageSchema = isAbout ? JSON.stringify({
	"@context": "https://schema.org",
	"@type": "AboutPage",
	"name": title,
	"description": metaDescription,
	"url": canonicalURL,
	"mainEntity": {
		"@type": "Organization",
		"name": "Cristalina",
		"url": siteUrl,
		"foundingDate": "2019",
		"foundingLocation": {
			"@type": "Place",
			"name": "San José, Costa Rica"
		},
		"areaServed": {
			"@type": "Country",
			"name": "Costa Rica"
		},
		"knowsAbout": [
			"Water Purification",
			"Ultrafiltration",
			"Water Treatment"
		]
	}
}) : null;

// Structured Data - ContactPage
const isContact = slug === 'contacto' || slug === 'contact';
const contactPageSchema = isContact ? JSON.stringify({
	"@context": "https://schema.org",
	"@type": "ContactPage",
	"name": title,
	"description": metaDescription,
	"url": canonicalURL,
	"mainEntity": {
		"@type": "Organization",
		"name": "Cristalina",
		"email": "info@cristalinacr.com",
		"telephone": "+(506) 8849-5919",
		"address": {
			"@type": "PostalAddress",
			"addressLocality": "San Rafael Abajo de Desamparados",
			"addressRegion": "San José",
			"addressCountry": "CR"
		},
		"openingHoursSpecification": {
			"@type": "OpeningHoursSpecification",
			"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
			"opens": "08:00",
			"closes": "17:00"
		}
	}
}) : null;

// Structured Data - HowTo (como-funciona / how-it-works)
const isHowItWorks = slug === 'como-funciona' || slug === 'how-it-works';
const howToSchema = isHowItWorks ? JSON.stringify({
	"@context": "https://schema.org",
	"@type": "HowTo",
	"name": locale === 'es' ? "Proceso de Filtración de Agua en 5 Etapas" : "5-Stage Water Filtration Process",
	"description": metaDescription,
	"step": [
		{
			"@type": "HowToStep",
			"position": 1,
			"name": locale === 'es' ? "Filtración de Sedimentos" : "Sediment Filtration",
			"text": locale === 'es'
				? "Filtración a 1 micra que elimina partículas sólidas como arena, óxido y sedimentos."
				: "1-micron filtration that removes solid particles like sand, rust, and sediments."
		},
		{
			"@type": "HowToStep",
			"position": 2,
			"name": locale === 'es' ? "Pre-Carbón Activado" : "Pre-Activated Carbon",
			"text": locale === 'es'
				? "Filtración a 0.5 micras que elimina antibióticos, cloro e ingredientes carcinógenos."
				: "0.5-micron filtration that removes antibiotics, chlorine, and carcinogenic ingredients."
		},
		{
			"@type": "HowToStep",
			"position": 3,
			"name": locale === 'es' ? "Eliminación de Metales Pesados" : "Heavy Metal Removal",
			"text": locale === 'es'
				? "Elimina metales pesados y compuestos orgánicos que causan decoloración y olores."
				: "Removes heavy metals and organic compounds that cause discoloration and odors."
		},
		{
			"@type": "HowToStep",
			"position": 4,
			"name": locale === 'es' ? "Ultrafiltración" : "Ultrafiltration",
			"text": locale === 'es'
				? "Membrana semi-permeable que filtra a 0.01 micras, permitiendo solo agua limpia y minerales."
				: "Semi-permeable membrane filtering at 0.01 microns, allowing only clean water and minerals."
		},
		{
			"@type": "HowToStep",
			"position": 5,
			"name": locale === 'es' ? "Post-Carbón GAC" : "Post-Carbon GAC",
			"text": locale === 'es'
				? "Filtro final de carbón activado granular que elimina olores y sabores residuales."
				: "Final granular activated carbon filter that removes residual odors and tastes."
		}
	]
}) : null;
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://images.ctfassets.net" crossorigin />
		<link rel="preload" href="/fonts/plus-jakarta-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/outfit-latin.woff2" as="font" type="font/woff2" crossorigin />
		<SEO
			title={fullTitle}
			titleTemplate={isHome ? undefined : "%s | Cristalina"}
			description={metaDescription}
			canonical={canonicalURL}
			languageAlternates={[
				{ href: esUrl, hrefLang: "es" },
				{ href: enUrl, hrefLang: "en" },
				{ href: esUrl, hrefLang: "x-default" }
			]}
			openGraph={{
				basic: {
					title: fullTitle,
					type: isProduct ? "product" : "website",
					image: ogImageUrl,
					url: canonicalURL
				},
				optional: {
					description: metaDescription,
					locale: locale === 'es' ? 'es_CR' : 'en_US',
					localeAlternate: [locale === 'es' ? 'en_US' : 'es_CR'],
					siteName: "Cristalina"
				},
				image: {
					alt: title,
					width: 1200,
					height: 630
				}
			}}
			twitter={{
				card: "summary_large_image",
				title: fullTitle,
				description: metaDescription,
				image: ogImageUrl,
				imageAlt: title
			}}
			extend={{
				link: [
					{ rel: "sitemap", href: "/sitemap-index.xml" }
				],
				meta: [
					{ name: "theme-color", content: "#01a89e" },
					{ name: "author", content: "Cristalina" }
				]
			}}
		/>
		<script is:inline type="application/ld+json" set:html={organizationSchema} />
		<script is:inline type="application/ld+json" set:html={breadcrumbSchema} />
		{localBusinessSchema && <script is:inline type="application/ld+json" set:html={localBusinessSchema} />}
		{webSiteSchema && <script is:inline type="application/ld+json" set:html={webSiteSchema} />}
		{productSchema && <script is:inline type="application/ld+json" set:html={productSchema} />}
		{aboutPageSchema && <script is:inline type="application/ld+json" set:html={aboutPageSchema} />}
		{contactPageSchema && <script is:inline type="application/ld+json" set:html={contactPageSchema} />}
		{howToSchema && <script is:inline type="application/ld+json" set:html={howToSchema} />}
		<script is:inline>document.documentElement.classList.add('js')</script>
	</head>
	<body class="font-jakarta">
		<Navigation links={navigation.links} locale={locale} />
		<main>
			<slot />
		</main>
		{footer && <Footer {...footer} />}
		<script>
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('animate-fade-in-up');
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.2 }
			);
			document.querySelectorAll('.fade-on-scroll').forEach((el) => observer.observe(el));
		</script>
	</body>
</html>
