---
import type { MappedContactSection } from '../lib/mapContent';
import LucideIcon from './icons/LucideIcon.astro';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';

type Props = MappedContactSection;

const { title, description, email, phone, whatsapp, schedule } = Astro.props;
---

<section class="py-16 md:py-24 px-4 bg-base-100 relative overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: radial-gradient(circle at 20% 30%, #01a89e 0%, transparent 50%), radial-gradient(circle at 80% 70%, #004a59 0%, transparent 50%)"
  />
  <div class="max-w-6xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

      {/* Contact info — left side */}
      <div class="lg:col-span-2 fade-on-scroll">
        {title && (
          <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4">
            {title}
          </h2>
        )}
        {description && (
          <p class="text-base-content/60 leading-relaxed mb-10">
            {description}
          </p>
        )}

        <div class="space-y-6">
          {phone && (
            <a
              href={`tel:${phone}`}
              class="group flex items-center gap-4 hover:text-primary transition-colors"
            >
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center group-hover:bg-primary transition-colors duration-300">
                <LucideIcon name="Phone" size={20} strokeWidth={1.5} class="text-primary group-hover:text-white transition-colors duration-300" />
              </div>
              <div>
                <p class="text-xs text-base-content/50 font-semibold uppercase tracking-wider mb-0.5">Teléfono</p>
                <p class="text-[15px] font-bold">{phone}</p>
              </div>
            </a>
          )}

          {email && (
            <a
              href={`mailto:${email}`}
              class="group flex items-center gap-4 hover:text-primary transition-colors"
            >
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center group-hover:bg-primary transition-colors duration-300">
                <LucideIcon name="Mail" size={20} strokeWidth={1.5} class="text-primary group-hover:text-white transition-colors duration-300" />
              </div>
              <div>
                <p class="text-xs text-base-content/50 font-semibold uppercase tracking-wider mb-0.5">Email</p>
                <p class="text-[15px] font-bold">{email}</p>
              </div>
            </a>
          )}

          {whatsapp && (
            <a
              href={`https://wa.me/${whatsapp}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-4 hover:text-primary transition-colors"
            >
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center group-hover:bg-primary transition-colors duration-300">
                <WhatsAppIcon size={20} class="text-primary group-hover:text-white transition-colors duration-300" />
              </div>
              <div>
                <p class="text-xs text-base-content/50 font-semibold uppercase tracking-wider mb-0.5">WhatsApp</p>
                <p class="text-[15px] font-bold">Envíenos un mensaje</p>
              </div>
            </a>
          )}

          {schedule && (
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center">
                <LucideIcon name="Clock" size={20} strokeWidth={1.5} class="text-primary" />
              </div>
              <div>
                <p class="text-xs text-base-content/50 font-semibold uppercase tracking-wider mb-0.5">Horario</p>
                <p class="text-[15px] font-bold">{schedule}</p>
              </div>
            </div>
          )}
        </div>
      </div>

      {/* Contact form — right side */}
      <div class="lg:col-span-3 fade-on-scroll" style="animation-delay: 150ms">
        <div class="bg-base-200/50 rounded-3xl p-8 md:p-10 border border-base-300/40">
          <h3 class="text-xl font-bold mb-6">Envíenos un mensaje</h3>
          <form id="contact-form" class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="contact-name" class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-1.5 block">Nombre</label>
                <input
                  id="contact-name"
                  type="text"
                  name="name"
                  required
                  class="input input-bordered w-full bg-base-100 focus:border-primary focus:outline-none transition-colors"
                  placeholder="Su nombre"
                />
              </div>
              <div>
                <label for="contact-phone" class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-1.5 block">Teléfono</label>
                <input
                  id="contact-phone"
                  type="tel"
                  name="phone"
                  class="input input-bordered w-full bg-base-100 focus:border-primary focus:outline-none transition-colors"
                  placeholder="8888-8888"
                />
              </div>
            </div>
            <div>
              <label for="contact-email" class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-1.5 block">Email</label>
              <input
                id="contact-email"
                type="email"
                name="email"
                required
                class="input input-bordered w-full bg-base-100 focus:border-primary focus:outline-none transition-colors"
                placeholder="su@email.com"
              />
            </div>
            <div>
              <label for="contact-message" class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-1.5 block">Mensaje</label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="4"
                class="textarea textarea-bordered w-full bg-base-100 focus:border-primary focus:outline-none transition-colors resize-none"
                placeholder="¿En qué podemos ayudarle?"
              />
            </div>
            <button
              type="submit"
              class="btn btn-primary btn-lg w-full font-bold text-lg tracking-wide shadow-lg shadow-primary/20"
            >
              Enviar Mensaje
              <LucideIcon name="Send" size={18} strokeWidth={2} class="ml-1" />
            </button>
          </form>

          {/* Success message (hidden by default) */}
          <div id="contact-success" class="hidden text-center py-10">
            <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
              <LucideIcon name="CheckCircle" size={32} strokeWidth={1.5} class="text-primary" />
            </div>
            <h3 class="text-xl font-bold mb-2">¡Mensaje Enviado!</h3>
            <p class="text-base-content/60">Nos pondremos en contacto con usted pronto.</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('contact-success');
  if (form && success) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      // TODO: Connect to form service (Netlify Forms, EmailJS, etc.)
      form.classList.add('hidden');
      success.classList.remove('hidden');
    });
  }
</script>
