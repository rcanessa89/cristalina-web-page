---
import type { MappedContactSection } from '../lib/mapContent';
import LucideIcon from './icons/LucideIcon.astro';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';
import { slugify } from '../lib/utils';

type Props = MappedContactSection & { locale?: string };

const { title, description, email, phone, whatsapp, schedule, locale = 'es' } = Astro.props;
const sectionId = title ? slugify(title) : undefined;
const isEs = locale === 'es';

const t = {
  phone: isEs ? 'Teléfono' : 'Phone',
  email: 'Email',
  whatsapp: 'WhatsApp',
  whatsappCta: isEs ? 'Envíenos un mensaje' : 'Send us a message',
  schedule: isEs ? 'Horario' : 'Hours',
  formTitle: isEs ? 'Envíenos un mensaje' : 'Send us a message',
  name: isEs ? 'Nombre' : 'Name',
  namePlaceholder: isEs ? 'Su nombre' : 'Your name',
  phonePlaceholder: '8888-8888',
  emailPlaceholder: isEs ? 'su@email.com' : 'your@email.com',
  message: isEs ? 'Mensaje' : 'Message',
  messagePlaceholder: isEs ? '¿En qué podemos ayudarle?' : 'How can we help you?',
  submit: isEs ? 'Enviar Mensaje' : 'Send Message',
  successTitle: isEs ? '¡Mensaje Enviado!' : 'Message Sent!',
  successText: isEs ? 'Nos pondremos en contacto con usted pronto.' : 'We will get back to you soon.',
  errorText: isEs ? 'Hubo un error al enviar. Por favor intente de nuevo.' : 'There was an error sending. Please try again.',
};
---

<section id={sectionId} class="py-16 md:py-24 px-4 bg-base-100 relative overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: radial-gradient(circle at 20% 30%, #01a89e 0%, transparent 50%), radial-gradient(circle at 80% 70%, #004a59 0%, transparent 50%)"
  />
  <div class="max-w-6xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

      {/* Contact info — left side */}
      <div class="lg:col-span-2 fade-on-scroll">
        {title && (
          <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4">
            {title}
          </h2>
        )}
        {description && (
          <p class="text-base-content/60 leading-relaxed mb-10">
            {description}
          </p>
        )}

        <div class="space-y-6">
          {phone && (
            <a
              href={`tel:${phone}`}
              class="group flex items-center gap-4 hover:text-primary transition-colors"
            >
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center group-hover:bg-primary transition-colors duration-300">
                <LucideIcon name="Phone" size={20} strokeWidth={1.5} class="text-primary group-hover:text-white transition-colors duration-300" />
              </div>
              <div>
                <p class="text-xs text-base-content/50 font-semibold uppercase tracking-wider mb-0.5">{t.phone}</p>
                <p class="text-[15px] font-bold">{phone}</p>
              </div>
            </a>
          )}

          {email && (
            <a
              href={`mailto:${email}`}
              class="group flex items-center gap-4 hover:text-primary transition-colors"
            >
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center group-hover:bg-primary transition-colors duration-300">
                <LucideIcon name="Mail" size={20} strokeWidth={1.5} class="text-primary group-hover:text-white transition-colors duration-300" />
              </div>
              <div>
                <p class="text-xs text-base-content/50 font-semibold uppercase tracking-wider mb-0.5">{t.email}</p>
                <p class="text-[15px] font-bold">{email}</p>
              </div>
            </a>
          )}

          {whatsapp && (
            <a
              href={`https://wa.me/${whatsapp}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-4 hover:text-primary transition-colors"
            >
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center group-hover:bg-primary transition-colors duration-300">
                <WhatsAppIcon size={20} class="text-primary group-hover:text-white transition-colors duration-300" />
              </div>
              <div>
                <p class="text-xs text-base-content/50 font-semibold uppercase tracking-wider mb-0.5">{t.whatsapp}</p>
                <p class="text-[15px] font-bold">{t.whatsappCta}</p>
              </div>
            </a>
          )}

          {schedule && (
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center">
                <LucideIcon name="Clock" size={20} strokeWidth={1.5} class="text-primary" />
              </div>
              <div>
                <p class="text-xs text-base-content/50 font-semibold uppercase tracking-wider mb-0.5">{t.schedule}</p>
                <p class="text-[15px] font-bold">{schedule}</p>
              </div>
            </div>
          )}
        </div>
      </div>

      {/* Contact form — right side */}
      <div class="lg:col-span-3 fade-on-scroll" style="animation-delay: 150ms">
        <div class="bg-base-200/50 rounded-3xl p-8 md:p-10 border border-base-300/40">
          <h3 class="text-xl font-bold mb-6">{t.formTitle}</h3>
          <form id="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="space-y-5">
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden"><input name="bot-field" /></p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="contact-name" class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-1.5 block">{t.name}</label>
                <input
                  id="contact-name"
                  type="text"
                  name="name"
                  required
                  class="input input-bordered w-full bg-base-100 focus:border-primary focus:outline-none transition-colors"
                  placeholder={t.namePlaceholder}
                />
              </div>
              <div>
                <label for="contact-phone" class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-1.5 block">{t.phone}</label>
                <input
                  id="contact-phone"
                  type="tel"
                  name="phone"
                  class="input input-bordered w-full bg-base-100 focus:border-primary focus:outline-none transition-colors"
                  placeholder="8888-8888"
                />
              </div>
            </div>
            <div>
              <label for="contact-email" class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-1.5 block">{t.email}</label>
              <input
                id="contact-email"
                type="email"
                name="email"
                required
                class="input input-bordered w-full bg-base-100 focus:border-primary focus:outline-none transition-colors"
                placeholder={t.emailPlaceholder}
              />
            </div>
            <div>
              <label for="contact-message" class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-1.5 block">{t.message}</label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="4"
                class="textarea textarea-bordered w-full bg-base-100 focus:border-primary focus:outline-none transition-colors resize-none"
                placeholder={t.messagePlaceholder}
              />
            </div>
            <button
              type="submit"
              class="btn btn-primary btn-lg w-full font-bold text-lg tracking-wide shadow-lg shadow-primary/20"
            >
              {t.submit}
              <LucideIcon name="Send" size={18} strokeWidth={2} class="ml-1" />
            </button>
          </form>

          {/* Error message (hidden by default) */}
          <div id="contact-error" class="hidden text-center py-4 mb-4">
            <p class="text-error font-medium">{t.errorText}</p>
          </div>

          {/* Success message (hidden by default) */}
          <div id="contact-success" class="hidden text-center py-10">
            <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
              <LucideIcon name="CheckCircle" size={32} strokeWidth={1.5} class="text-primary" />
            </div>
            <h3 class="text-xl font-bold mb-2">{t.successTitle}</h3>
            <p class="text-base-content/60">{t.successText}</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('contact-success');
  const errorDiv = document.getElementById('contact-error');
  if (form && success) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (btn) {
        btn.disabled = true;
        btn.classList.add('loading');
      }
      try {
        const data = new FormData(form);
        const res = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(data as any).toString(),
        });
        if (res.ok) {
          form.classList.add('hidden');
          success.classList.remove('hidden');
        } else {
          throw new Error('Network error');
        }
      } catch {
        errorDiv?.classList.remove('hidden');
        if (btn) {
          btn.disabled = false;
          btn.classList.remove('loading');
        }
      }
    });
  }
</script>
