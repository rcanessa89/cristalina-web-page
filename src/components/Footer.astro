---
import type { MappedFooter } from '../lib/mapContent';
import LucideIcon from './icons/LucideIcon.astro';
import FacebookIcon from './icons/FacebookIcon.astro';
import InstagramIcon from './icons/InstagramIcon.astro';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';

type Props = MappedFooter & { locale?: string };

const { companyName, description, links, email, phone, address, facebook, instagram, whatsapp, locale = 'es' } = Astro.props;
const hasSocial = facebook || instagram || whatsapp;
const hasContact = email || phone || address;
---

<footer class="bg-neutral text-neutral-content">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div>
        <p class="text-2xl font-extrabold tracking-tight mb-3">{companyName}</p>
        {description && (
          <p class="text-neutral-content/60 leading-relaxed">{description}</p>
        )}
        {hasSocial && (
          <div class="flex gap-4 mt-6">
            {facebook && (
              <a
                href={facebook}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Facebook"
                class="w-10 h-10 rounded-full bg-neutral-content/10 flex items-center justify-center hover:bg-primary hover:text-primary-content transition-colors"
              >
                <FacebookIcon size={18} />
              </a>
            )}
            {instagram && (
              <a
                href={instagram}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
                class="w-10 h-10 rounded-full bg-neutral-content/10 flex items-center justify-center hover:bg-primary hover:text-primary-content transition-colors"
              >
                <InstagramIcon size={18} />
              </a>
            )}
            {whatsapp && (
              <a
                href={`https://wa.me/${whatsapp}`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="WhatsApp"
                class="w-10 h-10 rounded-full bg-neutral-content/10 flex items-center justify-center hover:bg-primary hover:text-primary-content transition-colors"
              >
                <WhatsAppIcon size={18} />
              </a>
            )}
          </div>
        )}
      </div>

      {links && links.length > 0 && (
        <div>
          <h6 class="text-sm font-semibold uppercase tracking-wider text-neutral-content/50 mb-4">
            {locale === 'es' ? 'Links' : 'Links'}
          </h6>
          <ul class="space-y-3">
            {links.map((link) =>
              link.children && link.children.length > 0 ? (
                <li>
                  <details class="footer-dropdown group">
                    <summary class="flex items-center gap-1 text-neutral-content/70 hover:text-primary transition-colors cursor-pointer select-none list-none">
                      {link.linkText}
                      <LucideIcon name="ChevronDown" size={14} class="transition-transform duration-200 group-open:rotate-180" />
                    </summary>
                    <ul class="mt-2 ml-4 space-y-2">
                      {link.children.map((child) => (
                        <li>
                          <a href={child.url} class="text-neutral-content/60 hover:text-primary transition-colors text-sm">
                            {child.linkText}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </details>
                </li>
              ) : (
                <li>
                  <a href={link.url} class="text-neutral-content/70 hover:text-primary transition-colors">
                    {link.linkText}
                  </a>
                </li>
              )
            )}
          </ul>
        </div>
      )}

      {hasContact && (
        <div>
          <h6 class="text-sm font-semibold uppercase tracking-wider text-neutral-content/50 mb-4">
            {locale === 'es' ? 'Contacto' : 'Contact'}
          </h6>
          <ul class="space-y-3">
            {phone && (
              <li>
                <a href={`tel:${phone}`} class="inline-flex items-center gap-3 text-neutral-content/70 hover:text-primary transition-colors">
                  <LucideIcon name="Phone" size={16} /> {phone}
                </a>
              </li>
            )}
            {email && (
              <li>
                <a href={`mailto:${email}`} class="inline-flex items-center gap-3 text-neutral-content/70 hover:text-primary transition-colors">
                  <LucideIcon name="Mail" size={16} /> {email}
                </a>
              </li>
            )}
            {address && (
              <li class="inline-flex items-start gap-3 text-neutral-content/70">
                <LucideIcon name="MapPin" size={16} class="shrink-0 mt-1" /> {address}
              </li>
            )}
          </ul>
        </div>
      )}
    </div>
  </div>
  <div class="border-t border-neutral-content/10 px-6 py-4">
    <p class="text-center text-sm text-neutral-content/40">
      &copy; {new Date().getFullYear()} {companyName}
    </p>
  </div>
</footer>
