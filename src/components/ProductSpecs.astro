---
import { Image } from 'astro:assets';
import type { MappedProductSpecs } from '../lib/mapContent';
import LucideIcon from './icons/LucideIcon.astro';
import { slugify } from '../lib/utils';

type Props = MappedProductSpecs;

const { title, description, image, items } = Astro.props;
const sectionId = title ? slugify(title) : undefined;
---

<section id={sectionId} class="py-16 md:py-24 px-4 bg-base-100 relative overflow-hidden">
  <div class="section-wave-top" />
  <div class="max-w-6xl mx-auto">
    {title && (
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-3">
          {title}
        </h2>
        {description && (
          <p class="text-base-content/60 text-lg max-w-2xl mx-auto">
            {description}
          </p>
        )}
      </div>
    )}

    <div class:list={['flex flex-col items-center gap-12', image && 'lg:flex-row lg:items-center lg:gap-16']}>
      {image && (
        <div class="flex-shrink-0 w-full max-w-md lg:w-[38%] fade-on-scroll">
          <div class="relative rounded-3xl bg-gradient-to-b from-secondary/5 to-base-200 border border-base-300/40 p-6 md:p-10 flex items-center justify-center">
            <div
              class="absolute inset-0 rounded-3xl opacity-[0.06]"
              style="background-image: radial-gradient(circle at 50% 60%, #01a89e 0%, transparent 70%)"
            />
            <Image
              src={image.url}
              alt={image.title || 'Product image'}
              width={image.width || 600}
              height={image.height || 600}
              class="relative z-10 w-full max-h-[460px] object-contain drop-shadow-xl"
            />
          </div>
        </div>
      )}

      <div class:list={['w-full', image && 'lg:w-[62%]']}>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {items.map((spec, index) => (
            <div
              class="group flex items-center gap-4 bg-base-200/40 rounded-xl px-5 py-4 border border-base-300/30 hover:border-primary/20 hover:shadow-md transition-all duration-300 fade-on-scroll"
              style={`animation-delay: ${(index % 4 + 1) * 80}ms`}
            >
              <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center group-hover:bg-primary transition-colors duration-300">
                <LucideIcon
                  name={spec.icon || 'CircleDot'}
                  size={20}
                  strokeWidth={1.5}
                  class="text-primary group-hover:text-white transition-colors duration-300"
                />
              </div>
              <div class="min-w-0">
                <p class="text-xs text-base-content/50 font-semibold uppercase tracking-wider leading-none mb-1">{spec.label}</p>
                <p class="text-[15px] font-bold text-base-content leading-tight">{spec.value}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
