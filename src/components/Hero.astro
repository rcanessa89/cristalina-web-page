---
import type { MappedHero } from '../lib/mapContent';
import LucideIcon from './icons/LucideIcon.astro';

type Props = MappedHero;

const { title, subtitle, backgroundImages, cta, variant = 'full' } = Astro.props;
const isCompact = variant === 'compact';
---

{isCompact ? (
  <section
    class="relative overflow-hidden py-20 md:py-28 px-4"
    style="background: linear-gradient(135deg, #004a59 0%, #01a89e 50%, #31cdcf 100%)"
  >
    <div class="section-wave-top" />
    <div
      class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.3) 0%, transparent 50%), radial-gradient(circle at 80% 50%, rgba(255,255,255,0.2) 0%, transparent 50%)"
    />
    <div class="relative z-10 max-w-2xl mx-auto text-center text-white">
      <h2 class="text-4xl md:text-5xl font-extrabold mb-4 animate-fade-in-up tracking-tight">
        {title}
      </h2>
      {subtitle && (
        <p class="text-lg md:text-xl mb-8 text-white/85 animate-fade-in-up delay-200">
          {subtitle}
        </p>
      )}
      {cta && (
        <a
          class="btn btn-lg btn-wide bg-white text-secondary border-none hover:bg-white/90 hover:scale-[1.02] shadow-xl shadow-black/20 font-bold animate-fade-in-up delay-300 text-lg tracking-wide"
          href={cta.url}
        >
          {cta.linkText}
        </a>
      )}
    </div>
  </section>
) : (
  <section class="hero relative min-h-screen overflow-hidden" data-hero-carousel>
    {backgroundImages.map((img, i) => (
      <div
        class="hero-slide absolute inset-0 bg-cover bg-center transition-opacity duration-[1200ms] ease-in-out"
        style={`background-image: url(${img.url}); opacity: ${i === 0 ? 1 : 0};`}
      />
    ))}
    <div
      class="absolute inset-0 z-10"
      style="background: linear-gradient(to bottom, rgba(0,74,89,0.5) 0%, rgba(0,74,89,0.3) 50%, rgba(26,26,46,0.7) 100%)"
    />
    <div class="hero-content relative z-20 text-center text-white">
      <div class="max-w-3xl">
        <h1 class="text-5xl md:text-7xl font-black mb-6 animate-fade-in-up tracking-tight" style="text-shadow: 0 2px 20px rgba(0,0,0,0.3)">
          {title}
        </h1>
        {subtitle && (
          <p class="text-xl md:text-2xl mb-8 text-white/90 font-light animate-fade-in-up delay-200" style="text-shadow: 0 1px 8px rgba(0,0,0,0.3)">
            {subtitle}
          </p>
        )}
        {cta && (
          <a
            class="btn btn-primary btn-lg shadow-lg shadow-primary/30 font-bold animate-fade-in-up delay-300"
            href={cta.url}
          >
            {cta.linkText}
          </a>
        )}
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-scroll-bounce">
      <LucideIcon name="ChevronDown" size={32} class="text-white/60" />
    </div>
  </section>
)}

<script>
  const carousel = document.querySelector('[data-hero-carousel]');
  if (carousel) {
    const slides = carousel.querySelectorAll<HTMLElement>('.hero-slide');
    if (slides.length > 1) {
      let active = 0;
      let intervalId: ReturnType<typeof setInterval> | null = null;

      function startCarousel() {
        if (!intervalId) {
          intervalId = setInterval(() => {
            slides[active].style.opacity = '0';
            active = (active + 1) % slides.length;
            slides[active].style.opacity = '1';
          }, 5000);
        }
      }

      function stopCarousel() {
        if (intervalId) {
          clearInterval(intervalId);
          intervalId = null;
        }
      }

      startCarousel();
      document.addEventListener('visibilitychange', () => {
        document.hidden ? stopCarousel() : startCarousel();
      });
    }
  }
</script>
