---
import type { MappedFeatureList } from '../lib/mapContent';
import LucideIcon from './icons/LucideIcon.astro';
import { slugify } from '../lib/utils';

type Props = MappedFeatureList;

const { title, items } = Astro.props;
const sectionId = title ? slugify(title) : undefined;
---

<section id={sectionId} class="py-14 md:py-20 px-4 bg-base-200 relative overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: radial-gradient(circle at 20% 30%, #01a89e 0%, transparent 50%), radial-gradient(circle at 80% 70%, #004a59 0%, transparent 50%)"
  />
  {title && (
    <h2 class="text-3xl md:text-4xl font-extrabold text-center mb-16 tracking-tight relative z-10">
      {title}
    </h2>
  )}
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 max-w-6xl mx-auto relative z-10">
    {items.map((feature, index) => (
      <div
        class="group relative bg-base-100 rounded-2xl p-8 pl-10 border border-base-300/50 hover:border-primary/20 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 fade-on-scroll overflow-hidden"
        style={`animation-delay: ${(index % 3 + 1) * 100}ms`}
      >
        <div class="absolute left-0 top-0 bottom-0 w-1 bg-primary/40 group-hover:bg-primary transition-colors duration-300" />
        <span class="absolute top-4 right-5 text-5xl font-black text-base-content/[0.04] select-none leading-none">
          {String(index + 1).padStart(2, '0')}
        </span>
        {feature.icon && (
          <div class="w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center mb-5 group-hover:bg-primary transition-all duration-300">
            <LucideIcon
              name={feature.icon}
              size={26}
              strokeWidth={1.5}
              class="text-primary group-hover:text-white transition-colors duration-300"
            />
          </div>
        )}
        {feature.image && (
          <figure class="mb-5 flex justify-start">
            <img
              src={feature.image.url}
              alt={feature.image.title}
              class="w-14 h-14 object-contain"
            />
          </figure>
        )}
        <h3 class="text-lg font-bold mb-2">{feature.title}</h3>
        {feature.description && (
          <p class="text-base-content/65 leading-relaxed text-sm">
            {feature.description}
          </p>
        )}
      </div>
    ))}
  </div>
</section>
