---
import type { MappedLogoBar } from '../lib/mapContent';

type Props = MappedLogoBar;

const { title, logos } = Astro.props;
const tripled = [...logos, ...logos, ...logos];
---

{logos.length > 0 && (
  <section class="py-16 px-4 bg-base-100 border-t border-base-300/50">
    {title && (
      <h2 class="text-2xl md:text-3xl font-extrabold text-center mb-12 tracking-tight text-base-content/80">
        {title}
      </h2>
    )}
    <div class="relative overflow-hidden max-w-6xl mx-auto">
      <div class="absolute left-0 top-0 bottom-0 w-20 bg-gradient-to-r from-base-100 to-transparent z-10" />
      <div class="absolute right-0 top-0 bottom-0 w-20 bg-gradient-to-l from-base-100 to-transparent z-10" />
      <div class="animate-marquee flex items-center gap-16 w-max">
        {tripled.map((logo, i) => (
          <img
            src={logo.url}
            alt={logo.title}
            class="h-10 md:h-12 w-auto shrink-0 object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
          />
        ))}
      </div>
    </div>
  </section>
)}
